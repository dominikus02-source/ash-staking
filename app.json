{
  "expo": {
    "name": "ASH COIN STAKING",
    "slug": "ash-coin-staking",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ash-icon.png",
    "scheme": "ashcoinstaking",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/ash-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#667eea"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ashcoin.staking",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID for quick and secure login",
        "NSPhotoLibraryUsageDescription": "We need access to your photos to update your profile picture",
        "NSCameraUsageDescription": "We need camera access to take profile photos"
      },
      "buildNumber": "1",
      "appTransportSecurity": {
        "exceptionDomains": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#667eea"
      },
      "package": "com.ashcoin.staking",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "INTERNET",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "config": {
        "googleSignIn": {
          "certificateHash": "532d5c34c240a248d5d4af5419f2a1f27beef8b4"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ASH COIN STAKING to access your photos to update your profile picture.",
          "cameraPermission": "Allow ASH COIN STAKING to access your camera to take profile photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ash-coin-staking"
      }
    }
  }
}

# Firebase Config for ASH STAKING
# Replace these values with your Firebase project credentials
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=ash-staking.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=ash-staking
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=ash-staking.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
EXPO_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID

# Google Sign-In Config
EXPO_PUBLIC_FIREBASE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID

# App Config
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=1.0.0

# Midtrans Config
EXPO_PUBLIC_MIDTRANS_CLIENT_KEY=YOUR_MIDTRANS_CLIENT_KEY
EXPO_PUBLIC_MIDTRANS_IS_PRODUCTION=false
